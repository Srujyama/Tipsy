default_platform(:ios)

WORKSPACE = "ios/Tipsy.xcworkspace"
SCHEME    = "Tipsy"

platform :ios do
  desc "Install CocoaPods"
  lane :pods do
    cocoapods(
      podfile: "ios/Podfile",
      repo_update: true,
      clean_install: false
    )
  end

  desc "Bump build number from App Store Connect latest + 1"
  lane :bump_build do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
      duration: 1200,
      in_house: false
    )
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.tipsy.app",
      initial_build_number: 0
    )
    increment_build_number(
      xcodeproj: "ios/Tipsy.xcodeproj",
      build_number: latest + 1
    )
  end

  desc "Build a signed Release archive"
  lane :build do
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "Tipsy.ipa"
    )
  end

  desc "Pods + bump + build + upload to TestFlight (internal)"
  lane :beta do
    pods
    bump_build
    build
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH")
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/Tipsy.ipa",
      skip_waiting_for_build_processing: true,
      changelog: ENV["CHANGELOG"] || "Internal build"
    )
  end

  desc "Submit current TestFlight build to App Store review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH")
    )
    deliver(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
