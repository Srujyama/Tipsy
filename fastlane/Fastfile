default_platform(:ios)

WORKSPACE = "ios/Tipsy.xcworkspace"
SCHEME    = "Tipsy"

platform :ios do
  desc "Install CocoaPods (uses scripts/pod-install.sh to bypass vendored bundler 1.17.2)"
  lane :pods do
    sh("../scripts/pod-install.sh")
  end

  desc "Bump build number from App Store Connect latest + 1"
  lane :bump_build do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH"),
      duration: 1200,
      in_house: false
    )
    latest = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.tipsyios.app",
      initial_build_number: 0
    )
    increment_build_number(
      xcodeproj: "ios/Tipsy.xcodeproj",
      build_number: latest + 1
    )
  end

  desc "Fetch or create Distribution cert + App Store provisioning profile"
  lane :signing do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH")
    )
    get_certificates(
      api_key: api_key,
      keychain_path: File.expand_path("~/Library/Keychains/login.keychain-db")
    )
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.tipsyios.app",
      force: true
    )
  end

  desc "Build a signed Release archive"
  lane :build do
    signing
    profile_name = lane_context[SharedValues::SIGH_NAME] || ENV["sigh_com.tipsyios.app_appstore_profile-name"]
    UI.message("Using provisioning profile: #{profile_name}")
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build",
      output_name: "Tipsy.ipa",
      xcodebuild_formatter: "",
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=G4H29PDG94",
        "'CODE_SIGN_IDENTITY=Apple Distribution'",
        "'PROVISIONING_PROFILE_SPECIFIER=#{profile_name}'"
      ].join(" "),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          "com.tipsyios.app" => profile_name
        }
      }
    )
  end

  desc "Pods + bump + build + upload to TestFlight (internal)"
  lane :beta do
    pods
    bump_build
    build
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH")
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/Tipsy.ipa",
      skip_waiting_for_build_processing: true,
      changelog: ENV["CHANGELOG"] || "Internal build"
    )
  end

  desc "Submit current TestFlight build to App Store review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_FILEPATH")
    )
    deliver(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
        export_compliance_uses_encryption: false
      }
    )
  end
end
